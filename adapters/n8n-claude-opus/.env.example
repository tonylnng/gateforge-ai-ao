# =============================================================================
# n8n-claude-opus adapter — environment variables
# Copy to .env (never commit real values)
# =============================================================================

# ---- Adapter ---------------------------------------------------------------
ADAPTER_N8N_HTTP_PORT=8204
ADAPTER_N8N_MAX_CONCURRENT=3
ADAPTER_N8N_TIMEOUT_SECONDS=1800

# ---- n8n -------------------------------------------------------------------
# Full webhook trigger URL of the AI Agent workflow in n8n
ADAPTER_N8N_WORKFLOW_URL=http://n8n:5678/webhook/<your-webhook-id>

# n8n REST API key (Settings → API → Create API Key)
ADAPTER_N8N_API_KEY=

# ---- Vercel AI Gateway -----------------------------------------------------
# Your Vercel AI Gateway API key (app.vercel.com → AI Gateway → API Keys)
ADAPTER_N8N_VERCEL_GATEWAY_KEY=

# Model to use (do not change unless Vercel releases a newer Opus)
ADAPTER_N8N_MODEL=anthropic/claude-opus-4.7

# ---- Optional: Opus 4.7 fast mode ------------------------------------------
# Up to 2.5x faster responses; higher per-token cost ($30/$150 per M tokens)
# Remove or set to 0 to use standard mode
CLAUDE_CODE_ENABLE_OPUS_4_7_FAST_MODE=0
CLAUDE_CODE_SKIP_FAST_MODE_ORG_CHECK=0

# ---- n8n self-hosted (only if using bundled n8n profile) -------------------
N8N_HOST=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://n8n:5678
N8N_ENCRYPTION_KEY=                    # 32+ char random string
N8N_JWT_SECRET=                        # 32+ char random string
