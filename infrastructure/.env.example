# =============================================================================
# GateForge AI-AO — Environment Configuration (example)
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#   ./scripts/generate-secrets.sh   # auto-fills random secrets where empty
#
# NEVER commit .env to Git.  .env is in .gitignore.
# =============================================================================

# ---- Deployment ------------------------------------------------------------
DEPLOY_ENV=dev                # dev | staging | prod
PROJECT_NAME=gateforge-ai-ao
TZ=Asia/Hong_Kong

# Public hostname for ingress (Traefik / Caddy).  Leave blank for localhost.
PUBLIC_HOST=

# ---- NATS JetStream --------------------------------------------------------
NATS_HOST=nats
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222
NATS_CLUSTER_PORT=6222
NATS_JS_DOMAIN=aiao
NATS_JS_STORE_DIR=/data/jetstream
NATS_MAX_PAYLOAD=8MB
# Auth — set during bootstrap (see scripts/generate-secrets.sh)
NATS_OPERATOR_JWT=
NATS_SYS_ACCOUNT_JWT=
NATS_AIAO_ACCOUNT_JWT=
NATS_ORCHESTRATOR_USER_JWT=
NATS_ORCHESTRATOR_USER_SEED=
NATS_ADAPTER_USER_JWT=
NATS_ADAPTER_USER_SEED=

# ---- MinIO (S3) ------------------------------------------------------------
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=aiao-admin
MINIO_ROOT_PASSWORD=                  # 32+ char random; generate-secrets.sh fills
MINIO_REGION=ap-east-1
MINIO_BUCKET_ARTIFACTS=aiao-artifacts
MINIO_BUCKET_LOGS=aiao-logs
MINIO_BUCKET_TRACES=aiao-traces
# Service-account creds (used by orchestrator/adapters; created by buckets.yaml)
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ---- Postgres --------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aiao
POSTGRES_USER=aiao
POSTGRES_PASSWORD=                    # generate-secrets.sh fills
POSTGRES_SSL_MODE=disable             # set 'require' in prod with cert
# Connection string used by orchestrator
POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${POSTGRES_SSL_MODE}

# ---- Orchestrator ----------------------------------------------------------
ORCH_HTTP_PORT=8080
ORCH_GRPC_PORT=8081
ORCH_LOG_LEVEL=info                   # trace|debug|info|warn|error
ORCH_METRICS_PORT=9100
ORCH_HMAC_SECRET=                     # for webhook signing; generate-secrets.sh fills
ORCH_GIT_REPO_URL=                    # https://github.com/<org>/<your-project>.git
ORCH_GIT_BRANCH=main
ORCH_GIT_TOKEN=                       # PAT or GitHub App installation token

# ---- GitHub App (optional but recommended) ---------------------------------
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=

# ---- Observability ---------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAMESPACE=gateforge-aiao
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=               # generate-secrets.sh fills
TEMPO_HOST=tempo
LOKI_HOST=loki

# ---- Adapters --------------------------------------------------------------
# Perplexity Computer (API-based)
ADAPTER_PPLX_ENABLED=true
ADAPTER_PPLX_BASE_URL=https://api.perplexity.ai
ADAPTER_PPLX_API_KEY=
ADAPTER_PPLX_HTTP_PORT=8201

# Manus (browser-based via Playwright)
ADAPTER_MANUS_ENABLED=false
ADAPTER_MANUS_BASE_URL=https://manus.im
ADAPTER_MANUS_SESSION_PATH=/secrets/manus-session.json
ADAPTER_MANUS_HTTP_PORT=8202

# OpenClaw (native NATS adapter)
ADAPTER_OPENCLAW_ENABLED=true
ADAPTER_OPENCLAW_HTTP_PORT=8203
ADAPTER_OPENCLAW_GUIDELINE_REPO=https://github.com/tonylnng/gateforge-openclaw-guideline.git

# ---- Policy / Routing ------------------------------------------------------
POLICY_FILE=/config/policy.yaml
POLICY_DEFAULT_DENY=true
POLICY_BUDGET_DAILY_USD=50
POLICY_BUDGET_MONTHLY_USD=500
